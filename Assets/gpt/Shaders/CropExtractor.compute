#pragma kernel CSMain

AppendStructuredBuffer<float4> OutBuffer;
Texture2D<float4> FieldMap;
int MapSize;
float FieldWorldSize;
int TargetCropType;

[numthreads(8, 8, 1)]
void CSMain (uint3 id : SV_DispatchThreadID)
{
    if (id.x >= MapSize || id.y >= MapSize) return;

    float4 data = FieldMap.Load(int3(id.xy, 0));
    int type = (int)round(data.r * 255.0);
    float growth = data.g;

    if (type == TargetCropType && growth > 0)
    {
        float2 uv = id.xy / (float)MapSize;
        float2 pos = uv * FieldWorldSize;
        OutBuffer.Append(float4(pos.x, growth, pos.y, 0));
    }
}
