{
  "mcpServers": {
    "unity-ui-mcp": {
      "type": "sse",
      "url": "http://localhost:7890/sse"
    },
    "csharp-analyzer": {
      "command": "dotnet",
      "args": [
        "run",
        "--project",
        "tools/CSharpAnalyzerMcp"
      ],
      "env": {
        "PROJECT_PATH": "./wheat-farm.sln"
      }
    }
  }
}