{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "csharp-analyzer": {
      "type": "local",
      "command": [
        "dotnet",
        "run",
        "--project",
        "tools/CSharpAnalyzerMcp"
      ],
      "environment": {
        "PROJECT_PATH": "./wheat-farm.sln"
      },
      "enabled": true
    },
    "unityMCP": {
      "type": "local",
      "command": [
        "C:\\Users\\spole\\.local\\bin\\uvx.exe",
        "--from",
        "mcpforunityserver",
        "mcp-for-unity",
        "--transport",
        "stdio"
      ],
      "enabled": true
    },
    "unity-ui-mcp": {
      "type": "remote",
      "url": "http://localhost:7890/sse",
      "enabled": true,
      "timeout": 10000
    },
    "obsidian": {
      "type": "local",
      "command": [
        "cmd",
        "/c",
        "npx",
        "-y",
        "obsidian-mcp",
        "D:\\ObsidianVaults\\Vaults\\wheat-farm",
        "D:\\ObsidianVaults\\Vaults\\dev-knowledge"
      ],
      "enabled": true,
      "timeout": 30000
    }
  }
}
